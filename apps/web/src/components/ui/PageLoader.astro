---

<div
  id="page-loader"
  class="fixed inset-0 z-50 flex items-center justify-center bg-c1"
>
  <canvas
    id="loader-canvas"
    class="w-[60vw] h-[60vw] md:w-[20vw] md:h-[20vw]"
  ></canvas>
</div>

<script>
  import { DotLottie } from "@lottiefiles/dotlottie-web";
  import { gsap } from "gsap";

  document.addEventListener("astro:page-load", () => {
    const loader = document.getElementById("page-loader") as HTMLElement | null;
    if (!loader) return;

    if (sessionStorage.getItem("loaderShown")) {
      loader.style.display = "none";
      document.body.style.overflow = "";
      return;
    }

    sessionStorage.setItem("loaderShown", "true");
    document.body.style.overflow = "hidden";

    const canvas = document.getElementById("loader-canvas") as HTMLCanvasElement;

    const player = new DotLottie({
      canvas,
      src: "/lottie/loading.json",
      loop: false,
      autoplay: true,
      renderConfig: { autoResize: true },
    });

    player.addEventListener("complete", () => {
      const tl = gsap.timeline({
        onComplete: () => {
          loader.style.display = "none";
          document.body.style.overflow = "";
        },
      });

      tl.to(canvas, { scale: 0.9, duration: 0.25, ease: "power2.inOut" });
      tl.to(canvas, { scale: 10, duration: 0.6, ease: "power2.in" }, "exit");
      tl.to(canvas, { opacity: 0, duration: 0.4, ease: "power2.in" }, "exit+=0.42");
      tl.to(loader, { opacity: 0, duration: 0.35, ease: "power2.in" }, "exit+=0.42");
    });
  });
</script>
