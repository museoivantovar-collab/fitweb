---
interface Props {
  youtubeId: string;
  titulo: string;
  playLabel: string;
}

const { youtubeId, titulo, playLabel } = Astro.props;
---

<div class="group flex flex-col h-full bg-c7 overflow-hidden">
  <!-- Thumbnail -->
  <div class="relative aspect-video overflow-hidden">
    <img
      src={`https://img.youtube.com/vi/${youtubeId}/maxresdefault.jpg`}
      alt={playLabel}
      class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
      loading="lazy"
    />
    <!-- Play button overlay -->
    <div class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/40 transition-colors">
      <img src="/icons/play_button.svg" alt="" aria-hidden="true" class="w-16 h-16 pointer-events-none" />
    </div>
  </div>

  <!-- Title -->
  <div class="bg-c7 p-4">
    <h3 class="text-c1 font-bold text-base md:text-lg leading-snug group-hover:opacity-80 transition-opacity line-clamp-2">
      {titulo}
    </h3>
  </div>
</div>
