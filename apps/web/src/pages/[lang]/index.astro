---
import BaseLayout from "../../layouts/BaseLayout.astro";

import { guardLocale, SUPPORTED_LOCALES, type Locale } from "../../lib/i18n";

import HeroSection from "../../components/home/HeroSection.astro";

import NoticiasPreviewSection from "../../components/home/NoticiasPreviewSection.astro";

import Wheel from "../../components/general/Wheel.astro";

import TiendaPreviewSection from "../../components/home/TiendaPreviewSection.astro";

import PageLoader from "../../components/ui/PageLoader.astro";


export function getStaticPaths() {
  return SUPPORTED_LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: string };
const invalid = guardLocale(lang);
if (invalid) return invalid;

const locale = lang as Locale;
---

<BaseLayout lang={locale} title="Inicio">
  <PageLoader />
  <HeroSection lang={locale} />
  <NoticiasPreviewSection lang={locale} />
  <Wheel lang={locale} />
  <TiendaPreviewSection lang={locale} />
</BaseLayout>
