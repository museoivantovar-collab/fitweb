---
import "../styles/global.css";
import type { Locale } from "../lib/i18n";
import Navbar from "../components/navigation/Navbar.astro";
import NavbarMobile from "../components/navigation/NavbarMobile.astro";
import Footer from "../components/navigation/Footer.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  lang: Locale;
  title: string;
  description?: string;
  hideFooter?: boolean;
}

const { lang, title, description = "Fundación", hideFooter = false } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Fundación</title>
    <ClientRouter />
  </head>
  <body class="min-h-screen bg-c1 text-c7 antialiased pt-16">
    <div class="hidden lg:block"><Navbar lang={lang} /></div>
    <div class="lg:hidden"><NavbarMobile lang={lang} /></div>
    <slot />
    {!hideFooter && <Footer lang={lang} />}
  </body>
</html>
