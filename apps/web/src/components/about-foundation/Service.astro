---
import LottiePlayer from "@/components/ui/LottiePlayer.astro";

interface Props {
  title: string;
  description: string;
  icon: string;
  href?: string;
}

const { title, description, icon, href } = Astro.props;
---

<article data-service-lottie class="w-full bg-c1 flex items-center justify-between gap-8 lg:gap-16 px-8 lg:px-0 lg:pl-24 py-12 lg:py-16">
  <!-- Left: icon + text -->
  <div class="flex flex-col items-start gap-4 md:flex-row md:items-center md:gap-8 lg:gap-16">
    {href
      ? <a href={href} class="shrink-0"><img src={icon} class="w-auto h-full" alt="" /></a>
      : <img src={icon} class="shrink-0 w-auto h-full" alt="" />
    }

    <div class="flex flex-col">
      <h2 class="text-xl lg:text-6xl font-black leading-none">
        {href ? <a href={href}>{title}</a> : title}
      </h2>
      <p class="mt-3 text-base lg:text-xl text-c7 max-w-2xl leading-relaxed">
        {description}
      </p>
    </div>
  </div>

  <!-- Right: tentaculo animation (hidden on mobile) -->
  <LottiePlayer
    src="/lottie/tentaculo.json"
    loop={false}
    autoplay={false}
    class="hidden lg:block shrink-0 lg:h-40"
    style="aspect-ratio: 1172 / 448; width: auto;"
  />
</article>

<style>
  /* ── Inactive (default) ───────────────────────────── */
  article[data-service-lottie] h2 {
    -webkit-text-stroke: .5px var(--color-c7);
    color: transparent;
    transition: color 0.5s ease;
  }

  article[data-service-lottie] div > img,
  article[data-service-lottie] div > a > img,
  article[data-service-lottie] p {
    opacity: 0.6;
    transition: opacity 0.5s ease;
  }

  /* ── Active ───────────────────────────────────────── */
  article[data-service-lottie][data-service-active] h2 {
    color: var(--color-c7);
  }

  article[data-service-lottie][data-service-active] div > img,
  article[data-service-lottie][data-service-active] div > a > img {
    opacity: 1;
  }

  article[data-service-lottie][data-service-active] p {
    opacity: 0.8;
  }

  /* ── Title link hover ─────────────────────────────── */
  article[data-service-lottie] h2 > a {
    color: inherit;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  article[data-service-lottie] h2 > a:hover {
    color: var(--color-c2);
    -webkit-text-stroke: 0;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import type { DotLottie } from "@lottiefiles/dotlottie-web";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("astro:page-load", () => {
    document
      .querySelectorAll<HTMLElement>("article[data-service-lottie]")
      .forEach((article) => {
        const canvas = article.querySelector<HTMLCanvasElement>("canvas[data-lottie-src]");
        if (!canvas) return;

        canvas.addEventListener("lottie:ready", (e) => {
          const { player } = (e as CustomEvent<{ player: DotLottie }>).detail;

          ScrollTrigger.create({
            trigger: article,
            start: "top center",
            end: "bottom center",
            onEnter:     () => { article.setAttribute("data-service-active", ""); player.setMode("forward"); player.play(); },
            onLeave:     () => { article.removeAttribute("data-service-active");  player.setMode("reverse"); player.play(); },
            onEnterBack: () => { article.setAttribute("data-service-active", ""); player.setMode("forward"); player.play(); },
            onLeaveBack: () => { article.removeAttribute("data-service-active");  player.setMode("reverse"); player.play(); },
          });
        });
      });
  });
</script>
