---
import type { Locale } from "@/lib/i18n";
import { useConservamosTranslations } from "./conservamos.i18n";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useConservamosTranslations(lang);
---

<header class="flex flex-col md:flex-row items-start md:items-center gap-5 px-8 md:px-12 lg:px-16 pt-16 pb-10">
  <img
    src="/assets/icons/conservamos_icon.svg"
    alt=""
    aria-hidden="true"
    class="shrink-0 w-auto h-full"
  />

  <div>
    <h1 class="text-5xl md:text-6xl font-black text-c7 leading-none">
      {t.pageTitle}
    </h1>
    <p class="mt-3 text-sm md:text-base text-c7/70 max-w-sm leading-relaxed">
      {t.description}
    </p>
  </div>
</header>
