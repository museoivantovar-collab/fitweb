# Public CMS API URL (accessible from the browser for SSR, or build env for SSG)
PUBLIC_CMS_URL=http://localhost:3000

# If using Cloudflare Pages, set SITE to the production URL
# SITE=https://fundacion.org

# Mailchimp — server-side only (never exposed to the browser)
MAILCHIMP_API_KEY=your-api-key-here-us18
MAILCHIMP_LIST_ID=your-audience-id-here
MAILCHIMP_DC=us18
