---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { guardLocale, SUPPORTED_LOCALES, type Locale } from "../../lib/i18n";
import GaleriaMasonrySection from "../../components/galeria/GaleriaMasonrySection.astro";

export function getStaticPaths() {
  return SUPPORTED_LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: string };
const invalid = guardLocale(lang);
if (invalid) return invalid;

const locale = lang as Locale;
---

<BaseLayout lang={locale} title="Galería">
  <GaleriaMasonrySection lang={locale} />
</BaseLayout>
